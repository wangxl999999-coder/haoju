<view class="page">
  <view class="header">
    <view class="logo">
      <text class="iconfont icon-book"></text>
    </view>
    <view class="title">好句好段</view>
    <view class="subtitle">汇聚精彩文字，记录美好瞬间</view>
  </view>

  <view class="form-section">
    <view class="form-item">
      <view class="input-wrap">
        <text class="iconfont icon-phone prefix-icon"></text>
        <input 
          class="input" 
          type="number" 
          placeholder="请输入手机号" 
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="input-wrap code-wrap">
        <text class="iconfont icon-lock prefix-icon"></text>
        <input 
          class="input code-input" 
          type="number" 
          placeholder="请输入验证码" 
          maxlength="6"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode">
          <text wx:if="{{countdown > 0}}">{{countdown}}s后重发</text>
          <text wx:else>获取验证码</text>
        </view>
      </view>
    </view>

    <view class="invite-item" wx:if="{{inviteCode}}">
      <view class="invite-label">邀请人ID：{{inviteCode}}</view>
    </view>

    <view class="btn-section">
      <button class="btn btn-primary btn-block" bindtap="handleLogin" loading="{{loading}}">
        登录/注册
      </button>
    </view>

    <view class="agreement">
      <checkbox class="agreement-checkbox" checked="{{agreed}}" bindtap="toggleAgreement"></checkbox>
      <text class="agreement-text">
        我已阅读并同意
        <text class="link" catchtap="viewAgreement">《用户协议》</text>
        和
        <text class="link" catchtap="viewPrivacy">《隐私政策》</text>
      </text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">好句好段 - 让文字更有温度</text>
  </view>
</view>
