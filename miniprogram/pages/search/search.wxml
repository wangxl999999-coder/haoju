<view class="page">
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="iconfont icon-search"></text>
      <input 
        class="search-input" 
        placeholder="搜索好句好段..." 
        value="{{keyword}}"
        bindinput="onKeywordInput"
        confirm-type="search"
        bindconfirm="handleSearch"
        focus="{{true}}"
      />
      <text class="iconfont icon-close" wx:if="{{keyword}}" bindtap="clearKeyword"></text>
    </view>
    <text class="cancel-btn" bindtap="goBack">取消</text>
  </view>

  <view class="hot-section" wx:if="{{hotKeywords.length > 0 && !hasSearched}}">
    <view class="section-header">
      <text class="section-title">热门搜索</text>
    </view>
    <view class="hot-tags">
      <text 
        class="hot-tag" 
        wx:for="{{hotKeywords}}" 
        wx:key="index"
        bindtap="searchKeyword"
        data-keyword="{{item}}"
      >
        {{item}}
      </text>
    </view>
  </view>

  <view class="history-section" wx:if="{{searchHistory.length > 0 && !hasSearched}}">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="clear-history" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <view 
        class="history-item" 
        wx:for="{{searchHistory}}" 
        wx:key="index"
        bindtap="searchKeyword"
        data-keyword="{{item}}"
      >
        <text class="iconfont icon-clock"></text>
        <text class="history-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="result-section" wx:if="{{hasSearched}}">
    <view class="result-header" wx:if="{{contentList.length > 0}}">
      <text class="result-text">共找到 {{total}} 条结果</text>
    </view>

    <view class="content-list" wx:if="{{contentList.length > 0}}">
      <view 
        class="content-item" 
        wx:for="{{contentList}}" 
        wx:key="id"
        bindtap="goDetail"
        data-id="{{item.id}}"
      >
        <view class="content-header">
          <text class="tag tag-primary">{{item.category_name}}</text>
          <text class="author" wx:if="{{item.author}}">{{item.author}}</text>
        </view>
        <view class="content-text ellipsis-3">{{item.content}}</view>
        <view class="content-footer">
          <view class="stats">
            <view class="stat-item">
              <text class="iconfont icon-view"></text>
              <text class="stat-text">{{item.view_count}}</text>
            </view>
            <view class="stat-item">
              <text class="iconfont {{item.is_favorite ? 'icon-heart-fill' : 'icon-heart'}}"></text>
              <text class="stat-text">{{item.favorite_count}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{contentList.length == 0 && !loading}}">
      <view class="empty-icon">
        <text class="iconfont icon-search"></text>
      </view>
      <text class="empty-text">未找到相关内容</text>
      <text class="empty-tip">换个关键词试试吧</text>
    </view>

    <view class="load-more" wx:if="{{contentList.length > 0}}">
      <text class="load-text" wx:if="{{loading}}">加载中...</text>
      <text class="load-text" wx:elif="{{noMore}}">没有更多了</text>
      <text class="load-text" wx:else bindtap="loadMore">上拉加载更多</text>
    </view>
  </view>
</view>
