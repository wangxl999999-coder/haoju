<view class="page">
  <view class="user-header" wx:if="{{userInfo}}">
    <view class="user-info">
      <view class="avatar">
        <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view wx:else class="avatar-placeholder">
          <text class="iconfont icon-user"></text>
        </view>
      </view>
      <view class="info-detail">
        <view class="nickname">{{userInfo.nickname}}</view>
        <view class="phone">{{userInfo.phone}}</view>
      </view>
    </view>
    <view class="points-card">
      <view class="points-info">
        <text class="points-label">我的积分</text>
        <text class="points-value">{{userInfo.points}}</text>
      </view>
      <view class="points-detail" bindtap="goPointsLog">
        <text class="detail-text">查看明细</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
  </view>

  <view class="login-prompt" wx:else>
    <view class="prompt-icon">
      <text class="iconfont icon-user"></text>
    </view>
    <view class="prompt-text">登录后可发布内容、收藏好句</view>
    <button class="btn btn-primary btn-small" bindtap="goLogin">立即登录</button>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goMyPublish">
      <view class="menu-left">
        <view class="menu-icon publish">
          <text class="iconfont icon-edit"></text>
        </view>
        <text class="menu-text">我的发布</text>
      </view>
      <text class="iconfont icon-arrow-right"></text>
    </view>

    <view class="menu-item" bindtap="goFavorites">
      <view class="menu-left">
        <view class="menu-icon favorite">
          <text class="iconfont icon-heart"></text>
        </view>
        <text class="menu-text">我的收藏</text>
      </view>
      <text class="iconfont icon-arrow-right"></text>
    </view>

    <view class="menu-item" bindtap="goInvite">
      <view class="menu-left">
        <view class="menu-icon invite">
          <text class="iconfont icon-share"></text>
        </view>
        <text class="menu-text">邀请好友</text>
      </view>
      <view class="menu-right">
        <text class="tag tag-primary">+1积分</text>
        <text class="iconfont icon-arrow-right"></text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="editProfile">
      <view class="menu-left">
        <view class="menu-icon setting">
          <text class="iconfont icon-setting"></text>
        </view>
        <text class="menu-text">编辑资料</text>
      </view>
      <text class="iconfont icon-arrow-right"></text>
    </view>

    <view class="menu-item" bindtap="viewAgreement">
      <view class="menu-left">
        <view class="menu-icon doc">
          <text class="iconfont icon-doc"></text>
        </view>
        <text class="menu-text">用户协议</text>
      </view>
      <text class="iconfont icon-arrow-right"></text>
    </view>

    <view class="menu-item" bindtap="viewPrivacy">
      <view class="menu-left">
        <view class="menu-icon privacy">
          <text class="iconfont icon-lock"></text>
        </view>
        <text class="menu-text">隐私政策</text>
      </view>
      <text class="iconfont icon-arrow-right"></text>
    </view>
  </view>

  <view class="logout-section" wx:if="{{userInfo}}">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <view class="footer">
    <text class="footer-text">好句好段 v1.0.0</text>
  </view>

  <view class="edit-modal" wx:if="{{showEditModal}}" catchtouchmove="preventMove">
    <view class="modal-mask" bindtap="hideEditModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">编辑资料</text>
        <text class="iconfont icon-close" bindtap="hideEditModal"></text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">昵称</text>
          <input class="form-input" placeholder="请输入昵称" value="{{editNickname}}" bindinput="onEditNickname" maxlength="20" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="cancel-btn" bindtap="hideEditModal">取消</button>
        <button class="confirm-btn" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>
</view>
