.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 40rpx;
}

.user-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 40rpx 30rpx 60rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder .iconfont {
  font-size: 60rpx;
  color: #FFFFFF;
}

.info-detail {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.points-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 30rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 10rpx;
}

.points-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.points-detail {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.3);
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #FFFFFF;
  margin-right: 8rpx;
}

.points-detail .iconfont {
  font-size: 24rpx;
  color: #FFFFFF;
}

.login-prompt {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 80rpx 30rpx 100rpx;
  border-radius: 0 0 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.prompt-icon {
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.prompt-icon .iconfont {
  font-size: 80rpx;
  color: #FFFFFF;
}

.prompt-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 30rpx;
}

.login-prompt .btn {
  border: none;
  background-color: #FFFFFF;
  color: #FF6B6B;
}

.login-prompt .btn::after {
  border: none;
}

.menu-section {
  background-color: #FFFFFF;
  margin: 20rpx 30rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon.publish {
  background-color: #FFF5F5;
}

.menu-icon.favorite {
  background-color: #FFF5F5;
}

.menu-icon.invite {
  background-color: #FFF5F5;
}

.menu-icon.setting {
  background-color: #F5F5F5;
}

.menu-icon.doc {
  background-color: #F5F5F5;
}

.menu-icon.privacy {
  background-color: #F5F5F5;
}

.menu-icon .iconfont {
  font-size: 32rpx;
  color: #FF6B6B;
}

.menu-icon.setting .iconfont,
.menu-icon.doc .iconfont,
.menu-icon.privacy .iconfont {
  color: #666666;
}

.menu-text {
  font-size: 30rpx;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-right .tag {
  margin-right: 16rpx;
}

.menu-item .iconfont {
  font-size: 28rpx;
  color: #CCCCCC;
}

.logout-section {
  padding: 60rpx 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #FFFFFF;
  color: #FF6B6B;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #CCCCCC;
}

.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 80%;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-header .iconfont {
  font-size: 32rpx;
  color: #999999;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.form-input {
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
}

.cancel-btn {
  background-color: #FFFFFF;
  color: #999999;
}

.confirm-btn {
  background-color: #FF6B6B;
  color: #FFFFFF;
}

.cancel-btn::after,
.confirm-btn::after {
  border: none;
}
