.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 140rpx;
}

.content-card {
  background-color: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.content-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.content-header .stats {
  display: flex;
  align-items: center;
}

.content-header .stat-item {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
}

.content-header .stat-item .iconfont {
  font-size: 28rpx;
  color: #999999;
  margin-right: 8rpx;
}

.content-header .stat-item .stat-text {
  font-size: 24rpx;
  color: #999999;
}

.content-body {
  padding: 40rpx 30rpx;
}

.content-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

.content-text {
  font-size: 32rpx;
  color: #333333;
  line-height: 2;
  margin-bottom: 30rpx;
  text-align: justify;
}

.content-author {
  font-size: 28rpx;
  color: #666666;
  text-align: right;
  font-style: italic;
}

.content-footer {
  padding: 20rpx 30rpx;
  background-color: #FAFAFA;
}

.publish-info {
  display: flex;
  align-items: center;
}

.publish-label {
  font-size: 24rpx;
  color: #999999;
}

.publish-time {
  font-size: 24rpx;
  color: #999999;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  padding: 10rpx;
}

.bar-item .iconfont {
  font-size: 40rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.bar-item .iconfont.active {
  color: #FF6B6B;
}

.bar-item .bar-text {
  font-size: 22rpx;
  color: #999999;
}

.bar-item.copy-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.bar-item.copy-btn::after {
  border: none;
}
