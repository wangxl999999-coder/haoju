.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 30rpx;
}

.category-tabs {
  background-color: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-container {
  display: inline-flex;
  padding: 0 20rpx;
}

.tab-item {
  display: inline-block;
  padding: 30rpx 30rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 2rpx;
  transition: width 0.3s ease;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  width: 40rpx;
}

.content-list {
  padding: 20rpx 30rpx;
}

.content-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.content-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.content-header .author {
  font-size: 24rpx;
  color: #999999;
}

.content-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.content-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.content-footer .stats {
  display: flex;
  align-items: center;
}

.content-footer .stat-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
}

.content-footer .stat-item .iconfont {
  font-size: 28rpx;
  color: #999999;
  margin-right: 8rpx;
}

.content-footer .stat-item .stat-text {
  font-size: 24rpx;
  color: #999999;
}

.content-footer .favorite-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #FFF5F5;
  border-radius: 20rpx;
}

.content-footer .favorite-btn .iconfont {
  font-size: 28rpx;
  color: #FF6B6B;
  margin-right: 8rpx;
}

.content-footer .favorite-btn .btn-text {
  font-size: 24rpx;
  color: #FF6B6B;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background-color: #F0F0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon .iconfont {
  font-size: 80rpx;
  color: #CCCCCC;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more .load-text {
  font-size: 26rpx;
  color: #999999;
}
