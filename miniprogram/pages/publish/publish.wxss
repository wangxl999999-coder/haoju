.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 40rpx;
}

.form-section {
  background-color: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label .required {
  color: #FF6B6B;
  margin-right: 8rpx;
}

.form-label text {
  font-size: 28rpx;
  color: #333333;
}

.form-label .tip {
  font-size: 24rpx;
  color: #999999;
  margin-left: 10rpx;
}

.picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
}

.picker-wrap .placeholder {
  color: #999999;
}

.picker-wrap .iconfont {
  font-size: 28rpx;
  color: #999999;
}

.form-input {
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-textarea {
  width: 100%;
  min-height: 300rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.word-count {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999999;
}

.word-count .error {
  color: #FF6B6B;
}

.tips-section {
  background-color: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-item .iconfont {
  font-size: 32rpx;
  color: #FF6B6B;
  margin-right: 12rpx;
  margin-top: 2rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}

.btn-section {
  padding: 40rpx 30rpx;
}

.btn-section .btn {
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.btn-section .btn::after {
  border: none;
}
