.page {
  min-height: 100vh;
  background-color: #F5F7FA;
  padding-bottom: 30rpx;
}

.summary-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
}

.summary-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.summary-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 10rpx;
}

.summary-value {
  font-size: 64rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.summary-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

.list-section {
  background-color: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.section-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.log-list {
  padding: 0 30rpx;
}

.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.log-item:last-child {
  border-bottom: none;
}

.log-left {
  display: flex;
  align-items: center;
}

.log-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.log-icon.plus {
  background-color: rgba(82, 196, 26, 0.1);
}

.log-icon.minus {
  background-color: rgba(255, 77, 79, 0.1);
}

.log-icon .iconfont {
  font-size: 36rpx;
}

.log-icon.plus .iconfont {
  color: #52C41A;
}

.log-icon.minus .iconfont {
  color: #FF4D4F;
}

.log-info {
  display: flex;
  flex-direction: column;
}

.log-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.log-time {
  font-size: 24rpx;
  color: #999999;
}

.log-right {
  display: flex;
  align-items: center;
}

.points-value {
  font-size: 32rpx;
  font-weight: 600;
}

.points-value.plus {
  color: #52C41A;
}

.points-value.minus {
  color: #FF4D4F;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background-color: #F0F0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.empty-icon .iconfont {
  font-size: 60rpx;
  color: #CCCCCC;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more .load-text {
  font-size: 26rpx;
  color: #999999;
}
