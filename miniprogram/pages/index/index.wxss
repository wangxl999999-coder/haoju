.page {
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: linear-gradient(180deg, #FF6B6B 0%, #FF8E8E 100%);
}

.search-input {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
}

.search-input .iconfont {
  font-size: 32rpx;
  color: #999999;
  margin-right: 16rpx;
}

.search-input .placeholder {
  font-size: 28rpx;
  color: #999999;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
}

.section-header .title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  position: relative;
}

.section-header .title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-left: -20rpx;
}

.section-header .date {
  font-size: 26rpx;
  color: #999999;
}

.daily-section {
  margin-top: 20rpx;
}

.daily-card {
  margin: 0 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.daily-card::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.daily-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.daily-content {
  position: relative;
  z-index: 1;
}

.daily-content .content-text {
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 1.8;
  font-weight: 500;
}

.daily-footer {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 30rpx;
}

.daily-footer .author {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.daily-footer .tags {
  display: flex;
  align-items: center;
}

.daily-footer .tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.daily-stats {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.daily-stats .stat-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.daily-stats .stat-item .iconfont {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 10rpx;
}

.daily-stats .stat-item .stat-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.category-section {
  margin-top: 20rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  box-sizing: border-box;
}

.category-item .category-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFE5E5 0%, #FFF0F0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.category-item.active .category-icon {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  transform: scale(1.1);
}

.category-item .category-icon .iconfont {
  font-size: 48rpx;
  color: #FF6B6B;
}

.category-item.active .category-icon .iconfont {
  color: #FFFFFF;
}

.category-item .category-name {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
}

.category-item.active .category-name {
  color: #FF6B6B;
  font-weight: 500;
}

.content-section {
  margin-top: 20rpx;
}

.content-list {
  padding: 0 30rpx;
}

.content-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.content-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.content-header .author {
  font-size: 24rpx;
  color: #999999;
}

.content-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.content-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.content-footer .stats {
  display: flex;
  align-items: center;
}

.content-footer .stat-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
}

.content-footer .stat-item .iconfont {
  font-size: 28rpx;
  color: #999999;
  margin-right: 8rpx;
}

.content-footer .stat-item .stat-text {
  font-size: 24rpx;
  color: #999999;
}

.content-footer .favorite-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #FFF5F5;
  border-radius: 20rpx;
}

.content-footer .favorite-btn .iconfont {
  font-size: 28rpx;
  color: #FF6B6B;
  margin-right: 8rpx;
}

.content-footer .favorite-btn .btn-text {
  font-size: 24rpx;
  color: #FF6B6B;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more .load-text {
  font-size: 26rpx;
  color: #999999;
}
