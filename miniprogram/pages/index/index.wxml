<view class="page">
  <view class="search-bar" bindtap="goSearch">
    <view class="search-input">
      <text class="iconfont icon-search"></text>
      <text class="placeholder">搜索好句好段...</text>
    </view>
  </view>

  <view class="daily-section">
    <view class="section-header">
      <text class="title">每日推荐</text>
      <text class="date">{{today}}</text>
    </view>
    <view class="daily-card" wx:if="{{dailyContent.id}}" bindtap="goDetail" data-id="{{dailyContent.id}}">
      <view class="daily-content">
        <text class="content-text">{{dailyContent.content}}</text>
      </view>
      <view class="daily-footer">
        <text class="author" wx:if="{{dailyContent.author}}">—— {{dailyContent.author}}</text>
        <view class="tags">
          <text class="tag tag-primary">{{dailyContent.category_name}}</text>
        </view>
      </view>
      <view class="daily-stats">
        <view class="stat-item">
          <text class="iconfont icon-view"></text>
          <text class="stat-text">{{dailyContent.view_count}}</text>
        </view>
        <view class="stat-item">
          <text class="iconfont {{dailyContent.is_favorite ? 'icon-heart-fill' : 'icon-heart'}}"></text>
          <text class="stat-text">{{dailyContent.favorite_count}}</text>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text class="empty-text">暂无推荐内容</text>
    </view>
  </view>

  <view class="category-section">
    <view class="section-header">
      <text class="title">分类浏览</text>
    </view>
    <view class="category-grid">
      <view 
        class="category-item {{item.id == selectedCategory ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="id"
        bindtap="selectCategory"
        data-id="{{item.id}}"
      >
        <view class="category-icon">
          <text class="iconfont {{getCategoryIcon(item.id)}}"></text>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="content-section">
    <view class="section-header">
      <text class="title">{{currentCategoryName || '精彩内容'}}</text>
    </view>
    <view class="content-list">
      <view 
        class="content-item" 
        wx:for="{{contentList}}" 
        wx:key="id"
        bindtap="goDetail"
        data-id="{{item.id}}"
      >
        <view class="content-header">
          <text class="tag tag-primary">{{item.category_name}}</text>
          <text class="author" wx:if="{{item.author}}">{{item.author}}</text>
        </view>
        <view class="content-text ellipsis-3">{{item.content}}</view>
        <view class="content-footer">
          <view class="stats">
            <view class="stat-item">
              <text class="iconfont icon-view"></text>
              <text class="stat-text">{{item.view_count}}</text>
            </view>
            <view class="stat-item">
              <text class="iconfont {{item.is_favorite ? 'icon-heart-fill' : 'icon-heart'}}"></text>
              <text class="stat-text">{{item.favorite_count}}</text>
            </view>
          </view>
          <view class="favorite-btn" catchtap="toggleFavorite" data-id="{{item.id}}" data-index="{{index}}">
            <text class="iconfont {{item.is_favorite ? 'icon-heart-fill' : 'icon-heart'}}"></text>
            <text class="btn-text">{{item.is_favorite ? '已收藏' : '收藏'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="load-more" wx:if="{{contentList.length > 0}}">
      <text class="load-text" wx:if="{{loading}}">加载中...</text>
      <text class="load-text" wx:elif="{{noMore}}">没有更多了</text>
      <text class="load-text" wx:else bindtap="loadMore">上拉加载更多</text>
    </view>
    <view class="empty" wx:if="{{contentList.length == 0 && !loading}}">
      <text class="empty-text">暂无内容</text>
    </view>
  </view>
</view>
